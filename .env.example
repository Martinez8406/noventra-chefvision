# Chefvision – przykładowa konfiguracja zmiennych środowiskowych
# Skopiuj do .env.local i uzupełnij wartości.
# Na Vercel ustaw te zmienne w Project Settings → Environment Variables.

# ===== Supabase (baza danych, auth, storage) =====
# Vite (lokalnie): użyj zmiennych z prefixem VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Fallbacks (jeśli uruchamiasz w środowisku, które czyta process.env)
# Backend (server/index.js, /api/*) odczytuje też VITE_* z .env.local — możesz zduplikować URL/klucz tutaj jako SUPABASE_* dla pewności.
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== Google Gemini (generowanie obrazów AI) =====
GEMINI_API_KEY=

# ===== OpenAI (tłumaczenie menu – endpoint /api/translate-dish na serwerze) =====
OPENAI_API_KEY=

# ===== Stripe (płatności Premium) – serwer API =====
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Signing secret from Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Service role key (Project Settings → API) — required for /api/stripe/webhook (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ===== Opcjonalne =====
# URL aplikacji (dla success/cancel redirect Stripe). Lokalnie zwykle :3000.
BASE_URL=http://localhost:3000

# Port frontendu Vite (domyślnie 3000; jeśli zajęty, Vite wybierze następny wolny).
VITE_DEV_PORT=3000

# Port backendu API (Stripe + /api/generate-image). Domyślnie 3002.
STRIPE_API_PORT=
