# Chefvision – przykładowa konfiguracja zmiennych środowiskowych
# Skopiuj do .env.local i uzupełnij wartości.
# Na Vercel ustaw te zmienne w Project Settings → Environment Variables.

# ===== Supabase (baza danych, auth, storage) =====
# Vite (lokalnie): użyj zmiennych z prefixem VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Fallbacks (jeśli uruchamiasz w środowisku, które czyta process.env)
# Backend (server/index.js, /api/*) odczytuje też VITE_* z .env.local — możesz zduplikować URL/klucz tutaj jako SUPABASE_* dla pewności.
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== Google Gemini (generowanie obrazów AI) =====
GEMINI_API_KEY=

# ===== OpenAI (tłumaczenie menu – endpoint /api/translate-dish na serwerze) =====
OPENAI_API_KEY=

# ===== Stripe (płatności Premium) – serwer API =====
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# ===== Opcjonalne =====
# URL aplikacji (dla success/cancel redirect). Na Vercel automatycznie używany jest VERCEL_URL.
BASE_URL=

# Port backendu API (Stripe + /api/generate-image). Domyślnie 3002 — żeby nie kolidować z inną stroną na 3001.
STRIPE_API_PORT=
